# Database — use Neon pooled URL in prod (with ?pgbouncer=true&connection_limit=1)
DATABASE_URL="postgresql://arham:arham_dev@localhost:5433/arham_ipd?schema=public"
# Direct (non-pooled) URL for prisma migrate deploy. Optional in dev.
DIRECT_URL=""

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Storage
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR="./uploads"

# Google Drive (set STORAGE_DRIVER=gdrive to enable; required in prod)
GOOGLE_SERVICE_ACCOUNT_KEY=""
GOOGLE_DRIVE_FOLDER_ID=""

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Timezone: the clinic is in India, so the server runtime is pinned to
# Asia/Kolkata in src/instrumentation.ts — TZ is a Vercel *reserved* env var
# and can't be set in project env. The DB still stores UTC; report text also
# pins Asia/Kolkata explicitly.

# Cron auth — REQUIRED for the daily cleanup-pending-media job. Vercel sends it
# as `Authorization: Bearer <CRON_SECRET>`; without it the cron returns 500 and
# never sweeps abandoned PENDING uploads. Generate: openssl rand -hex 32
CRON_SECRET=""

# Production seed gate — leave unset/empty in prod by default; set to
# "yes" only when intentionally seeding a fresh production database.
# ALLOW_PROD_SEED=""
