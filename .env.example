# Database — use Neon pooled URL in prod (with ?pgbouncer=true&connection_limit=1)
DATABASE_URL="postgresql://arham:arham_dev@localhost:5433/arham_ipd?schema=public"
# Direct (non-pooled) URL for prisma migrate deploy. Optional in dev.
DIRECT_URL=""

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Storage
STORAGE_DRIVER="local"
LOCAL_UPLOAD_DIR="./uploads"

# Google Drive (set STORAGE_DRIVER=gdrive to enable; required in prod)
GOOGLE_SERVICE_ACCOUNT_KEY=""
GOOGLE_DRIVE_FOLDER_ID=""

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Production seed gate — leave unset/empty in prod by default; set to
# "yes" only when intentionally seeding a fresh production database.
# ALLOW_PROD_SEED=""
